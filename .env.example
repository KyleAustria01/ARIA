# ================================================================
# ARIA MVP 2.0 — Environment Variables
# ================================================================

# --- LLM Providers (fallback order: cerebras → groq → bedrock → gemini) ---
CEREBRAS_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- AWS Bedrock (optional — position 3 in fallback chain) ---
# https://console.aws.amazon.com/iam -> create user -> attach BedrockFullAccess policy
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
AWS_BEDROCK_API_KEY=

# --- STT (fallback order: groq whisper → faster-whisper local) ---
# Groq Whisper uses GROQ_API_KEY above
# faster-whisper runs locally, no key needed

# --- TTS ---
# ElevenLabs (free 10k chars/month → https://elevenlabs.io)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Web Search ---
# Tavily (free 1k searches/month → https://tavily.com)
TAVILY_API_KEY=

# --- Redis ---
# Local:   redis://localhost:6379
# Upstash: rediss://default:<password>@<host>:<port>  (free → https://upstash.com)
REDIS_URL=redis://localhost:6379
REDIS_TTL_HOURS=24

# --- App ---
SECRET_KEY=aria-change-this-in-production
APP_ENV=development
# Set to your Vercel URL in production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# --- Auth (optional) ---
RECRUITER_CREDENTIALS=

# ================================================================
# Frontend-only (VITE_ prefix) — set in Vercel dashboard
# ================================================================
# WebSocket URL pointing directly to your Render backend.
# Example: wss://aria-backend.onrender.com
# Leave empty for local dev (Vite dev proxy handles it automatically).
VITE_WS_URL=
